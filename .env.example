# ============================================================
#  AGRO SYSTEM — Environment Variables Template
#  Set ALL of these in Google Cloud Run environment variables
# ============================================================

# Flask
SECRET_KEY=replace-with-long-random-string-here

# Cloud SQL (MySQL) — Unix socket for Cloud Run
MYSQL_HOST=/cloudsql/YOUR_PROJECT_ID:YOUR_REGION:YOUR_INSTANCE_ID
MYSQL_USER=agro_user
MYSQL_PASSWORD=YourDatabasePassword
MYSQL_DB=agrosystem
MYSQL_PORT=3306

# Gmail SMTP (for email verification & password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-gmail-app-password
MAIL_DEFAULT_SENDER=Agro System <your-email@gmail.com>

# Payment — YOUR personal JazzCash / Easypaisa numbers
JAZZCASH_NUMBER=03001234567
EASYPAISA_NUMBER=03001234567
OWNER_NAME=Your Name

# Admin
ADMIN_EMAIL=admin@agrosystem.com
